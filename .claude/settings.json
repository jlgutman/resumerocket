{
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "allow": [
      "Bash(npx tsc *)"
    ]
  },
  "hooks": {
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '. + {logged_at: (now|todateiso8601)}' >> .claude/subagent-calls.log 2>/dev/null || true"
          }
        ]
      }
    ]
  }
}
